# 后端环境变量示例（复制为 .env 后按需修改）

# 数据库与缓存
DATABASE_URL=postgresql+asyncpg://netlearn:netlearn@db:5432/netlearn
REDIS_URL=redis://redis:6379/0

# JWT 鉴权
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_EXP_MINUTES=1440

# 靶机调度（Docker 守护进程地址，留空则使用本机默认 socket）
DOCKER_HOST=

# 实例配额与生命周期
INSTANCE_MAX_PER_USER=1
INSTANCE_TTL_MINUTES=60

# 主机端口分配范围（靶机端口映射）
HOST_PORT_RANGE_START=30000
HOST_PORT_RANGE_END=30100

# 管理员引导账号
ADMIN_BOOTSTRAP_EMAIL=admin@netlearn.local
ADMIN_BOOTSTRAP_PASSWORD=admin123456
